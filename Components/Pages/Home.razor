@page "/home"
@rendermode InteractiveServer
@using NutriFlow.Data
@using NutriFlow.Models
@using NutriFlow.Services
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@attribute [Authorize]

<PageTitle>Dashboard - NutriAI</PageTitle>

<div class="mb-8">
    <MudText Typo="Typo.h5" Class="font-bold">Bem-vindo ao NutriAI</MudText>
    <MudText Typo="Typo.body2" Color="Color.Surface" Style="color: #6b7280;">
        @DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR"))
    </MudText>
</div>

<!-- Stat Cards Row -->
<MudGrid Class="mb-6">
    <!-- Stat 1 -->
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="nutri-card h-100" Elevation="0">
            <div class="stat-card-container">
                <div>
                    <MudText Typo="Typo.caption" Style="color: #6b7280;">Pacientes Ativos</MudText>
                    <MudText Typo="Typo.h4" Class="font-bold mt-1">@pacientesCount</MudText>
                </div>
                <div class="stat-icon-wrapper icon-green">
                    <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Small" />
                </div>
            </div>
        </MudPaper>
    </MudItem>

    <!-- Stat 2 -->
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="nutri-card h-100" Elevation="0">
            <div class="stat-card-container">
                <div>
                    <MudText Typo="Typo.caption" Style="color: #6b7280;">Planos Ativos</MudText>
                    <MudText Typo="Typo.h4" Class="font-bold mt-1">@planosCount</MudText>
                </div>
                <div class="stat-icon-wrapper icon-blue">
                    <MudIcon Icon="@Icons.Custom.Uncategorized.FoodApple" Size="Size.Small" />
                </div>
            </div>
        </MudPaper>
    </MudItem>

    <!-- Stat 3 -->
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="nutri-card h-100" Elevation="0">
            <div class="stat-card-container">
                <div>
                    <MudText Typo="Typo.caption" Style="color: #6b7280;">Registros de Progresso</MudText>
                    <MudText Typo="Typo.h4" Class="font-bold mt-1">@progressosCount</MudText>
                </div>
                <div class="stat-icon-wrapper icon-orange">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                </div>
            </div>
        </MudPaper>
    </MudItem>

    <!-- Stat 4 -->
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="nutri-card h-100" Elevation="0">
            <div class="stat-card-container">
                <div>
                    <MudText Typo="Typo.caption" Style="color: #6b7280;">Sessões Registradas</MudText>
                    <MudText Typo="Typo.h4" Class="font-bold mt-1">@sessoesCount</MudText>
                </div>
                <div class="stat-icon-wrapper icon-purple">
                    <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Small" />
                </div>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- Recent Lists Row -->
<MudGrid>
    <!-- Pacientes Recentes -->
    <MudItem xs="12" md="6">
        <MudPaper Class="nutri-card pa-6 h-100" Elevation="0">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.subtitle1" Class="font-bold">Pacientes Recentes</MudText>
                <MudLink Href="/pacientes" Color="Color.Primary" Typo="Typo.body2" Underline="Underline.None">Ver todos →</MudLink>
            </div>
            
            <div class="d-flex flex-column gap-3">
                @if (pacientesRecentes.Any())
                {
                    @foreach (var p in pacientesRecentes)
                    {
                        <div class="d-flex justify-space-between align-center p-3 rounded-lg" style="background-color: #f9fafb; cursor: pointer;"
                             @onclick="@(() => NavigationManager.NavigateTo($"/pacientes/{p.Id}"))">
                            <div class="d-flex align-center gap-3">
                                <div class="avatar-initials">
                                    @(string.IsNullOrEmpty(p.Nome) ? "?" : p.Nome.Substring(0, 1).ToUpper())
                                </div>
                                <div>
                                    <MudText Typo="Typo.body2" Class="font-bold">@p.Nome</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #6b7280;">@(string.IsNullOrEmpty(p.Objetivo) ? "Geral" : p.Objetivo)</MudText>
                                </div>
                            </div>
                            <span class="status-badge @(p.Status == "ativo" ? "ativo" : "")">@(p.Status ?? "ativo")</span>
                        </div>
                    }
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="text-center pa-4" Style="color: #94a3b8;">Nenhum paciente cadastrado.</MudText>
                }
            </div>
        </MudPaper>
    </MudItem>

    <!-- Sessões Recentes -->
    <MudItem xs="12" md="6">
        <MudPaper Class="nutri-card pa-6 h-100" Elevation="0">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.subtitle1" Class="font-bold">Sessões Recentes</MudText>
                <MudLink Href="/sessoes" Color="Color.Primary" Typo="Typo.body2" Underline="Underline.None">Ver todas →</MudLink>
            </div>

            <div class="d-flex flex-column gap-3">
                @if (sessoesRecentes.Any())
                {
                    @foreach (var s in sessoesRecentes)
                    {
                        <div class="d-flex align-center p-3 rounded-lg gap-3" style="background-color: #f9fafb;">
                            <div class="stat-icon-wrapper icon-blue" style="width: 40px; height: 40px;">
                                <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Small" />
                            </div>
                            <div>
                                <MudText Typo="Typo.body2" Class="font-bold">@(s.Paciente?.Nome ?? "-")</MudText>
                                <MudText Typo="Typo.caption" Style="color: #6b7280;">
                                    @(s.DataSessao?.ToString("dd/MM/yyyy") ?? "-") · @(s.Tipo ?? "-")
                                </MudText>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="text-center pa-4" Style="color: #94a3b8;">Nenhuma sessão registrada.</MudText>
                }
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private int pacientesCount;
    private int planosCount;
    private int progressosCount;
    private int sessoesCount;

    private List<Paciente> pacientesRecentes = new();
    private List<Sessao> sessoesRecentes = new();

    [CascadingParameter]
    private Task<AuthenticationState> authenticationStateTask { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDashboardData();
            StateHasChanged();
        }
    }

    private async Task LoadDashboardData()
    {
        try
        {
            var authState = await authenticationStateTask;
            var userIdStr = authState.User.FindFirst("UsuarioId")?.Value;
            if (!int.TryParse(userIdStr, out var userId)) return;

            // IDs dos pacientes do usuário
            var pacienteIds = await DbContext.Pacientes
                .Where(p => p.UsuarioId == userId)
                .Select(p => p.Id)
                .ToListAsync();

            // Contadores
            pacientesCount = pacienteIds.Count;

            planosCount = await DbContext.PlanosDieta
                .Where(pd => pd.PacienteId != null && pacienteIds.Contains(pd.PacienteId.Value))
                .CountAsync();

            progressosCount = await DbContext.Progressos
                .Where(pr => pr.PacienteId != null && pacienteIds.Contains(pr.PacienteId.Value))
                .CountAsync();

            sessoesCount = await DbContext.Sessoes
                .Where(s => s.PacienteId != null && pacienteIds.Contains(s.PacienteId.Value))
                .CountAsync();

            // Pacientes recentes (últimos 5)
            pacientesRecentes = await DbContext.Pacientes
                .Where(p => p.UsuarioId == userId)
                .OrderByDescending(p => p.DataCadastro)
                .Take(3)
                .ToListAsync();

            // Sessões recentes (últimas 5)
            sessoesRecentes = await DbContext.Sessoes
                .Include(s => s.Paciente)
                .Where(s => s.PacienteId != null && pacienteIds.Contains(s.PacienteId.Value))
                .OrderByDescending(s => s.DataSessao)
                .Take(3)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar dashboard: {ex.InnerException?.Message ?? ex.Message}");
            Snackbar.Add("Erro ao carregar dados do dashboard.", Severity.Error);
        }
    }
}