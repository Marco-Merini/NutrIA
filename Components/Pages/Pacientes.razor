@page "/pacientes"
@rendermode InteractiveServer
@using NutriFlow.Data
@using NutriFlow.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject NutriFlow.Services.AuthService AuthService
<PageTitle>Pacientes - NutriAI</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h5" Class="font-bold">Pacientes</MudText>
        <MudText Typo="Typo.body2" Style="color: #6b7280;">Gerencie os perfis dos seus pacientes</MudText>
    </div>
    <MudButton Href="/pacientes/novo" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="rounded-lg text-none px-4">
        Novo Paciente
    </MudButton>
</div>

<!-- Search Bar -->
<div class="mb-6">
    <MudTextField @bind-Value="searchTerm" Placeholder="Buscar paciente por nome ou email..." 
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                  Variant="Variant.Outlined" Class="nutri-search-input bg-white" Underline="false" />
</div>

<!-- Patient List -->
<div class="d-flex flex-column gap-4">
    @if (FilteredPacientes.Any())
    {
        @foreach (var p in FilteredPacientes)
        {
            <MudPaper Class="nutri-card pa-4 d-flex justify-space-between align-center" Elevation="0">
                <div class="d-flex align-center gap-4">
                    <div class="avatar-initials" style="width: 48px; height: 48px; font-size: 1.1rem;">
                        @(string.IsNullOrEmpty(p.Nome) ? "?" : p.Nome.Substring(0, 1).ToUpper())
                    </div>
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="font-bold">@p.Nome</MudText>
                        <div class="d-flex align-center gap-3 mt-1">
                            <span class="status-badge" style="background-color: #e5f9f0; color: #2bd07b;">@(string.IsNullOrEmpty(p.Objetivo) ? "Sem Objetivo" : p.Objetivo)</span>
                            <MudText Typo="Typo.caption" Style="color: #6b7280;">@(p.PesoAtual?.ToString("0.##") ?? "0") kg</MudText>
                            <MudText Typo="Typo.caption" Style="color: #6b7280;">@p.Email</MudText>
                        </div>
                    </div>
                </div>
                <div class="d-flex align-center gap-4">
                    <span class="status-badge ativo">ativo</span>
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="color: #a0aabf;" Href="@($"/pacientes/{p.Id}")" />
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Color="Color.Error" OnClick="@(() => ConfirmarDelecao(p))" />
                </div>
            </MudPaper>
        }
    }
    else
    {
        <MudText Align="Align.Center" Class="py-4" Style="color:#6b7280">Nenhum paciente cadastrado ou encontrado.</MudText>
    }
</div>

@code {
    private string searchTerm = "";
    private List<Paciente> pacientes = new();

    private IEnumerable<Paciente> FilteredPacientes => string.IsNullOrWhiteSpace(searchTerm)
        ? pacientes
        : pacientes.Where(p => (p.Nome?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) || 
                               (p.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.InitializeAsync();
            await LoadPacientes();
            StateHasChanged();
        }
    }

    private async Task LoadPacientes()
    {
        try 
        {
            if (AuthService.CurrentUser != null)
            {
                var userId = AuthService.CurrentUser.Id;
                pacientes = await DbContext.Pacientes
                    .Where(p => p.UsuarioId == userId)
                    .ToListAsync();
            }
            else
            {
                NavigationManager.NavigateTo("/");
            }
        }
        catch 
        {
            Snackbar.Add("Erro ao carregar pacientes do banco de dados.", Severity.Error);
        }
    }

    private async Task ConfirmarDelecao(Paciente paciente)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Excluir Paciente", 
            $"Tem certeza que deseja deletar o paciente {paciente.Nome}? Esta ação não pode ser desfeita e todas as informações serão perdidas.", 
            yesText: "Sim, Excluir", cancelText: "Cancelar");
            
        if (result == true)
        {
            try
            {
                DbContext.Pacientes.Remove(paciente);
                await DbContext.SaveChangesAsync();
                
                pacientes.Remove(paciente);
                Snackbar.Add("Paciente deletado com sucesso.", Severity.Success);
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Erro ao deletar paciente: {ex.Message}", Severity.Error);
            }
        }
    }
}
