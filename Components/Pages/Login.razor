@page "/"
@rendermode InteractiveServer
@layout NutriFlow.Components.Layout.AuthLayout
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Login - NutrIA</PageTitle>

<MudPaper Elevation="3" Class="pa-8 d-flex flex-column rounded-xl" Width="400px" Style="border: 1px solid #e5e7eb;">
    <div class="d-flex justify-center mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Spa" Color="Color.Success" Size="Size.Large" />
    </div>

    <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-1 font-bold">Bem-vindo(a)</MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Style="color: #6b7280;" Class="mb-6">Faça login para acessar o NutrIA</MudText>

    <MudForm @ref="form" @bind-IsValid="@success">
        <MudTextField T="string"
                      @bind-Value="email"
                      Label="Email"
                      InputType="InputType.Email"
                      Required="true"
                      RequiredError="O email é obrigatório"
                      Variant="Variant.Outlined"
                      Class="mb-4 bg-white"
                      OnKeyUp="HandleKeyUp" />

        <MudTextField T="string"
                      @bind-Value="senha"
                      Label="Senha"
                      InputType="InputType.Password"
                      Required="true"
                      RequiredError="A senha é obrigatória"
                      Variant="Variant.Outlined"
                      Class="mb-6 bg-white"
                      OnKeyUp="HandleKeyUp" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" OnClick="DoLogin" Disabled="@isLoading" Class="rounded-lg py-3 font-bold text-white">
            @if (isLoading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Entrando...</MudText>
            }
            else
            {
                <text>Entrar</text>
            }
        </MudButton>
    </MudForm>

    <div class="d-flex justify-center mt-6">
        <MudText Typo="Typo.body2" Style="color: #6b7280;">Não tem uma conta? <MudLink Href="/cadastro" Color="Color.Primary" Underline="Underline.None" Class="font-bold">Cadastre-se</MudLink></MudText>
    </div>
</MudPaper>

@code {
    [SupplyParameterFromQuery]
    public int? error { get; set; }

    MudForm form = default!;
    bool success;
    private string email = "";
    private string senha = "";
    private bool isLoading;

    protected override void OnInitialized()
    {
        if (error == 1)
        {
            Snackbar.Add("Email ou senha incorretos.", Severity.Error);
        }
    }

    private async Task DoLogin()
    {
        await form.Validate();
        if (!form.IsValid) return;

        isLoading = true;
        StateHasChanged();

        // Submit via JS to create a real POST form submission (required for cookie auth)
        await JS.InvokeVoidAsync("submitLoginForm", email, senha);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isLoading)
        {
            await DoLogin();
        }
    }
}
