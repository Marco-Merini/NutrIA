@page "/"
@layout NutriFlow.Components.Layout.AuthLayout
@inject NavigationManager Navigation
@inject NutriFlow.Services.AuthService AuthService

<PageTitle>Login - NutriAI</PageTitle>

<MudPaper Elevation="3" Class="pa-8 d-flex flex-column rounded-xl" Width="400px" Style="border: 1px solid #e5e7eb;">
    <div class="d-flex justify-center mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Spa" Color="Color.Success" Size="Size.Large" />
    </div>
    
    <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-1 font-bold">Bem-vindo(a)</MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Style="color: #6b7280;" Class="mb-6">Faça login para acessar o NutriAI</MudText>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
    }

    <MudForm @ref="form" @bind-IsValid="@success" @bind-Errors="@errors">
        <MudTextField T="string" @bind-Value="nome" Label="Nome" InputType="InputType.Text" Required="true" RequiredError="O nome é obrigatório" Variant="Variant.Outlined" Class="mb-4 bg-white" />
        <MudTextField T="string" @bind-Value="senha" Label="Senha" InputType="InputType.Password" Required="true" RequiredError="A senha é obrigatória" Variant="Variant.Outlined" Class="mb-6 bg-white" />
        
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" OnClick="DoLogin" Disabled="@isLoading" Class="rounded-lg py-3 font-bold text-white">
            @if (isLoading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                <MudText Class="ms-2">Entrando...</MudText>
            }
            else
            {
                <text>Entrar</text>
            }
        </MudButton>
    </MudForm>

    <div class="d-flex justify-center mt-6">
        <MudText Typo="Typo.body2" Style="color: #6b7280;">Não tem uma conta? <MudLink Href="/cadastro" Color="Color.Primary" Underline="Underline.None" Class="font-bold">Cadastre-se</MudLink></MudText>
    </div>
</MudPaper>

@code {
    MudForm form;
    bool success;
    string[] errors = { };

    private string nome = "";
    private string senha = "";
    private bool isLoading;
    private string errorMessage = "";

    private async Task DoLogin()
    {
        await form.Validate();
        if (form.IsValid)
        {
            isLoading = true;
            errorMessage = "";
            
            var result = await AuthService.LoginAsync(nome, senha);
            if (result)
            {
                Navigation.NavigateTo("/");
            }
            else
            {
                errorMessage = "Nome ou senha incorretos.";
            }
            
            isLoading = false;
        }
    }
}
