@page "/planos"

<PageTitle>Planos Alimentares - NutriAI</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h5" Class="font-bold">Planos Alimentares</MudText>
        <MudText Typo="Typo.body2" Style="color: #6b7280;">Crie e gerencie dietas personalizadas com IA</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="rounded-lg text-none px-4">
        Novo Plano
    </MudButton>
</div>

<!-- Plans List -->
<div class="d-flex flex-column gap-4">
    @foreach (var p in planos)
    {
        <MudPaper Class="nutri-card pa-4 d-flex justify-space-between align-center" Elevation="0">
            <div class="d-flex align-center gap-4">
                <div class="stat-icon-wrapper icon-green" style="width: 48px; height: 48px;">
                    <MudIcon Icon="@Icons.Material.Filled.Fastfood" Size="Size.Medium" />
                </div>
                <div>
                    <MudText Typo="Typo.subtitle1" Class="font-bold">@p.Titulo</MudText>
                    <div class="d-flex align-center gap-2 mt-1">
                        <MudText Typo="Typo.caption" Style="color: #6b7280;">@p.PacienteNome</MudText>
                        <MudText Typo="Typo.caption" Style="color: #6b7280;">·</MudText>
                        <MudText Typo="Typo.caption" Style="color: #6b7280;">@p.Calorias kcal</MudText>
                        <MudText Typo="Typo.caption" Style="color: #6b7280;">·</MudText>
                        <MudText Typo="Typo.caption" Style="color: #6b7280;">@p.Refeicoes refeições</MudText>
                    </div>
                </div>
            </div>
            <div class="d-flex align-center gap-4">
                <span class="status-badge ativo">ativo</span>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Style="color: #6b7280;" />
                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Color="Color.Error" />
            </div>
        </MudPaper>
    }
</div>

@code {
    private List<PlanoViewModel> planos = new()
    {
        new() { Titulo = "Plano Hipocalórico - Março 2025", PacienteNome = "Ana Paula Ferreira", Calorias = 1600, Refeicoes = 5, Status = "ativo" },
        new() { Titulo = "Plano Hiperproteico - Ganho de Massa", PacienteNome = "Carlos Eduardo Silva", Calorias = 3200, Refeicoes = 5, Status = "ativo" }
    };

    public class PlanoViewModel
    {
        public string Titulo { get; set; } = "";
        public string PacienteNome { get; set; } = "";
        public int Calorias { get; set; }
        public int Refeicoes { get; set; }
        public string Status { get; set; } = "";
    }
}
