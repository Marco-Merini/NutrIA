@page "/sessoes"
@attribute [Authorize]
@rendermode InteractiveServer
@using NutriFlow.Data
@using NutriFlow.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NutriFlow.Services.AuthService AuthService

<PageTitle>Sessões - NutriAI</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h5" Class="font-bold">Sessões</MudText>
        <MudText Typo="Typo.body2" Style="color: #6b7280;">Registre e acompanhe as consultas</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="rounded-lg text-none px-4"
               OnClick="AbrirNovaSessao">
        Nova Sessão
    </MudButton>
</div>

@if (IsLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="d-block mx-auto mt-16" />
}
else if (!sessoes.Any())
{
    <MudPaper Class="pa-8 text-center" Elevation="0" Style="border: 1px solid #f1f5f9; border-radius: 12px;">
        <MudIcon Icon="@Icons.Material.Outlined.EventNote" Size="Size.Large" Style="color: #cbd5e1;" />
        <MudText Typo="Typo.h6" Class="mt-4 font-bold" Style="color: #94a3b8;">Nenhuma sessão registrada</MudText>
        <MudText Typo="Typo.body2" Style="color: #94a3b8;" Class="mt-1">Clique em "Nova Sessão" para registrar a primeira consulta.</MudText>
    </MudPaper>
}
else
{
    <!-- Sessions List -->
    <div class="d-flex flex-column gap-4">
        @foreach (var s in sessoes)
        {
            <MudPaper Class="nutri-card pa-4 d-flex justify-space-between align-start" Elevation="0">
                <div class="d-flex gap-4">
                    <div class="stat-icon-wrapper icon-blue" style="width: 48px; height: 48px; flex-shrink: 0;">
                        <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Medium" />
                    </div>
                    <div>
                        <div class="d-flex align-center gap-3 mb-1">
                            <MudText Typo="Typo.subtitle1" Class="font-bold">@(s.Paciente?.Nome ?? "-")</MudText>
                            @if (!string.IsNullOrWhiteSpace(s.Tipo))
                            {
                                <span class="status-badge" style="background-color: #eaf1fa; color: #5086e9;">@s.Tipo</span>
                            }
                        </div>
                        
                        <MudText Typo="Typo.caption" Style="color: #a0aabf; display: block;" Class="mb-3">
                            @(s.DataSessao?.ToString("dd/MM/yyyy") ?? "-")
                        </MudText>

                        @if (s.PesoSessao != null)
                        {
                            <div class="d-flex align-center gap-2 mb-2">
                                <MudText Typo="Typo.body2" Style="color: #6b7280;">Peso: @s.PesoSessao?.ToString("0.##") kg</MudText>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(s.Anotacoes))
                        {
                            <MudText Typo="Typo.body2" Style="color: #6b7280;" Class="mb-2">@s.Anotacoes</MudText>
                        }

                        <MudText Typo="Typo.caption" Style="color: #2bd07b; font-weight: 500;">
                            Próxima consulta: @(s.ProximaConsulta?.ToString("dd/MM/yyyy") ?? "A definir")
                        </MudText>
                    </div>
                </div>
                
                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => ExcluirSessao(s))" />
            </MudPaper>
        }
    </div>
}

@code {
    private List<Sessao> sessoes = new();
    private bool IsLoading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.InitializeAsync();


            await LoadSessoes();
            StateHasChanged();
        }
    }

    private async Task LoadSessoes()
    {
        IsLoading = true;
        try
        {
            var pacienteIds = await DbContext.Pacientes
                .Where(p => p.UsuarioId == AuthService.CurrentUser!.Id)
                .Select(p => p.Id)
                .ToListAsync();

            sessoes = await DbContext.Sessoes
                .Include(s => s.Paciente)
                .Where(s => s.PacienteId != null && pacienteIds.Contains(s.PacienteId.Value))
                .OrderByDescending(s => s.DataSessao)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar sessões: {ex.InnerException?.Message ?? ex.Message}");
            Snackbar.Add("Erro ao carregar sessões.", Severity.Error);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task AbrirNovaSessao()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true,
            CloseButton = true
        };
        var result = await DialogService.ShowAsync<NutriFlow.Components.Dialogs.NovaSessaoDialog>("Nova Sessão", options);
        var dialogResult = await result.Result;

        if (dialogResult != null && !dialogResult.Canceled)
        {
            await LoadSessoes();
            StateHasChanged();
        }
    }

    private async Task ExcluirSessao(Sessao sessao)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Confirmar exclusão",
            $"Deseja realmente excluir esta sessão de {sessao.Paciente?.Nome ?? "paciente"}?",
            yesText: "Excluir",
            cancelText: "Cancelar");

        if (confirm != true) return;

        try
        {
            DbContext.Sessoes.Remove(sessao);
            await DbContext.SaveChangesAsync();
            sessoes.Remove(sessao);
            Snackbar.Add("Sessão excluída com sucesso.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao excluir sessão: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
    }
}
