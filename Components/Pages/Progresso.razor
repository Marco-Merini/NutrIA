@page "/progresso"
@attribute [Authorize]
@rendermode InteractiveServer
@using NutriFlow.Models
@using NutriFlow.Services
@inject IProgressoService ProgressoService
@inject IPacienteService PacienteService
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Progresso - NutrIA</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h5" Class="font-bold">Monitoramento de Progresso</MudText>
        <MudText Typo="Typo.body2" Style="color: #6b7280;">Acompanhe a evolução dos pacientes</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="rounded-lg text-none px-4"
               OnClick="AbrirRegistrarProgresso">
        Registrar Progresso
    </MudButton>
</div>

<!-- Filtros de Pesquisa -->
<MudPaper Class="pa-4 mb-6" Elevation="0" Style="border: 1px solid #f1f5f9; border-radius: 12px; background-color: #ffffff;">
    <MudGrid Class="align-end">
        <MudItem xs="12" sm="4">
            <MudSelect T="int?" Label="Paciente" @bind-Value="filter.PacienteId" Clearable="true" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined" Margin="Margin.Dense">
                <MudSelectItem T="int?" Value="null">Todos os Pacientes</MudSelectItem>
                @foreach (var pac in pacientes)
                {
                    <MudSelectItem T="int?" Value="@((int?)pac.Id)">@pac.Nome</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudDatePicker @bind-Date="filter.DataInicio" Label="Data Início" Clearable="true" Editable="true" Format="dd/MM/yyyy" Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudDatePicker @bind-Date="filter.DataFim" Label="Data Fim" Clearable="true" Editable="true" Format="dd/MM/yyyy" Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" sm="2" Class="d-flex gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilters" FullWidth="true" Class="text-none rounded-lg py-2">
                Buscar
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="ResetFilters" FullWidth="true" Class="text-none rounded-lg py-2">
                Limpar
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (IsLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="d-block mx-auto mt-16" />
}
else
{
    <!-- Chart Area -->
    @if (paginatedResult.Items != null && paginatedResult.Items.Any(p => p.Peso != null))
    {
        <MudPaper Class="nutri-card pa-6 mb-6" Elevation="0" Style="border: 1px solid #f1f5f9; border-radius: 12px;">
            <MudText Typo="Typo.subtitle1" Class="font-bold mb-4">Evolução do Peso dos Pacientes</MudText>
            <MudChart ChartType="ChartType.Line" ChartSeries="@Series" @bind-SelectedIndex="Index" 
                      XAxisLabels="@XAxisLabels" Width="100%" Height="300px" ChartOptions="@Options" />
        </MudPaper>
    }

    <!-- Progress List -->
    @if (paginatedResult.Items == null || !paginatedResult.Items.Any())
    {
        <MudPaper Class="pa-8 text-center" Elevation="0" Style="border: 1px solid #f1f5f9; border-radius: 12px;">
            <MudIcon Icon="@Icons.Material.Outlined.TrendingUp" Size="Size.Large" Style="color: #cbd5e1;" />
            <MudText Typo="Typo.h6" Class="mt-4 font-bold" Style="color: #94a3b8;">Nenhum progresso encontrado</MudText>
            <MudText Typo="Typo.body2" Style="color: #94a3b8;" Class="mt-1">Tente ajustar seus filtros de busca ou registre um novo acompanhamento.</MudText>
        </MudPaper>
    }
    else
    {
        <div class="d-flex flex-column gap-4">
            @foreach (var p in paginatedResult.Items)
            {
                <MudPaper Class="nutri-card pa-4 d-flex justify-space-between align-start" Elevation="0" Style="border: 1px solid #f1f5f9; border-radius: 12px; transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="d-flex gap-4">
                        <div class="stat-icon-wrapper icon-orange" style="width: 48px; height: 48px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background-color: #fff3e0; color: #e65100; border-radius: 8px;">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Medium" />
                        </div>
                        <div>
                            <div class="d-flex align-center gap-3 mb-1">
                                <MudText Typo="Typo.subtitle2" Class="font-bold">@(p.PacienteNome ?? "-")</MudText>
                                <MudText Typo="Typo.caption" Style="color: #a0aabf;">@(p.DataRegistro?.ToString("dd/MM/yyyy") ?? "-")</MudText>
                            </div>
                            
                            <div class="d-flex align-center gap-3 mb-2" style="flex-wrap: wrap;">
                                @if (p.Peso != null)
                                {
                                    <MudText Typo="Typo.body2" Style="color: #6b7280;">@p.Peso?.ToString("0.##") kg</MudText>
                                }
                                @if (p.PercentualGordura != null)
                                {
                                    <MudText Typo="Typo.body2" Style="color: #6b7280;">Gordura: @p.PercentualGordura?.ToString("0.##")%</MudText>
                                }
                                @if (!string.IsNullOrWhiteSpace(p.AderenciaPlano))
                                {
                                    <span class="status-badge ativo">Aderência: @p.AderenciaPlano</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(p.Energia))
                                {
                                    <MudText Typo="Typo.body2" Style="color: #6b7280;">Energia: @p.Energia</MudText>
                                }
                                @if (!string.IsNullOrWhiteSpace(p.Humor))
                                {
                                    <MudText Typo="Typo.body2" Style="color: #6b7280;">Humor: @p.Humor</MudText>
                                }
                            </div>

                            <div class="d-flex align-center gap-3 mb-2" style="flex-wrap: wrap;">
                                @if (p.CinturaCm != null)
                                {
                                    <MudText Typo="Typo.caption" Style="color: #a0aabf;">Cintura: @p.CinturaCm?.ToString("0.##") cm</MudText>
                                }
                                @if (p.QuadrilCm != null)
                                {
                                    <MudText Typo="Typo.caption" Style="color: #a0aabf;">Quadril: @p.QuadrilCm?.ToString("0.##") cm</MudText>
                                }
                            </div>
                            
                            @if (!string.IsNullOrWhiteSpace(p.Feedback))
                            {
                                <MudText Typo="Typo.body2" Style="color: #6b7280;">@p.Feedback</MudText>
                            }
                        </div>
                    </div>
                    
                    <div class="d-flex align-center gap-2">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" 
                                       OnClick="@(() => AbrirEditarProgresso(p))" />
                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Color="Color.Error" 
                                       OnClick="@(() => ExcluirProgresso(p))" />
                    </div>
                </MudPaper>
            }
        </div>

        <!-- Paginação -->
        @if (paginatedResult.TotalPages > 1)
        {
            <div class="d-flex justify-center mt-6">
                <MudPagination SelectedChanged="OnPageChanged" Count="paginatedResult.TotalPages" Selected="filter.Page" Variant="Variant.Outlined" Color="Color.Primary" Class="rounded-lg" />
            </div>
        }
    }
}

@code {
    private int Index = -1;
    private bool IsLoading = true;

    private List<NutriFlow.Models.Paciente> pacientes = new();
    private ProgressoFilter filter = new() { Page = 1, PageSize = 10, SortBy = "DataRegistro", SortDirection = "desc" };
    private PaginatedResult<ProgressoResponseDto> paginatedResult = new();

    private ChartOptions Options { get; set; } = new()
    {
        LineStrokeWidth = 3,
        MaxNumYAxisTicks = 5,
        YAxisFormat = "0 'kg'",
        ChartPalette = new[] { "#e65100" }
    };

    public List<ChartSeries> Series { get; set; } = new();
    public string[] XAxisLabels { get; set; } = Array.Empty<string>();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.InitializeAsync();
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        IsLoading = true;
        try
        {
            var userId = AuthService.CurrentUser!.Id;
            if (!pacientes.Any())
            {
                pacientes = await PacienteService.GetPacientesByUsuarioIdAsync(userId);
            }
            paginatedResult = await ProgressoService.GetProgressosFiltradosAsync(userId, filter);
            AtualizarGrafico();
        }
        catch (Exception)
        {
            Snackbar.Add("Erro ao carregar progressos.", Severity.Error);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task ApplyFilters()
    {
        filter.Page = 1;
        await LoadData();
    }

    private async Task ResetFilters()
    {
        filter = new ProgressoFilter { Page = 1, PageSize = 10, SortBy = "DataRegistro", SortDirection = "desc" };
        await LoadData();
    }

    private async Task OnPageChanged(int newPage)
    {
        filter.Page = newPage;
        await LoadData();
    }

    private void AtualizarGrafico()
    {
        if (paginatedResult.Items != null && paginatedResult.Items.Any())
        {
            var dados = paginatedResult.Items
                .Where(p => p.Peso != null && p.DataRegistro != null)
                .OrderBy(p => p.DataRegistro)
                .ToList();

            if (dados.Any())
            {
                Series = new List<ChartSeries>()
                {
                    new ChartSeries()
                    {
                        Name = "Peso",
                        Data = dados.Select(p => (double)p.Peso!.Value).ToArray()
                    }
                };

                XAxisLabels = dados.Select(p => p.DataRegistro!.Value.ToString("dd/MM/yyyy")).ToArray();
            }
            else
            {
                Series = new List<ChartSeries>();
                XAxisLabels = Array.Empty<string>();
            }
        }
        else
        {
            Series = new List<ChartSeries>();
            XAxisLabels = Array.Empty<string>();
        }
    }

    private async Task AbrirRegistrarProgresso()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true,
            CloseButton = true
        };
        var result = await DialogService.ShowAsync<NutriFlow.Components.Dialogs.RegistrarProgressoDialog>("Registrar Progresso", options);
        var dialogResult = await result.Result;

        if (dialogResult != null && !dialogResult.Canceled)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task AbrirEditarProgresso(ProgressoResponseDto progressoDto)
    {
        var progressoCompleto = await ProgressoService.GetProgressoByIdAsync(progressoDto.Id);
        if (progressoCompleto == null)
        {
            Snackbar.Add("Erro ao carregar o progresso para edição.", Severity.Error);
            return;
        }

        var parameters = new DialogParameters { ["ProgressoModel"] = progressoCompleto };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true,
            CloseButton = true
        };
        var result = await DialogService.ShowAsync<NutriFlow.Components.Dialogs.EditarProgressoDialog>("Editar Progresso", parameters, options);
        var dialogResult = await result.Result;

        if (dialogResult != null && !dialogResult.Canceled)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task ExcluirProgresso(ProgressoResponseDto progresso)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Confirmar exclusão",
            $"Deseja realmente excluir este registro de progresso de {progresso.PacienteNome ?? "paciente"}?",
            yesText: "Excluir",
            cancelText: "Cancelar");

        if (confirm != true) return;

        try
        {
            var deleted = await ProgressoService.DeleteProgressoAsync(progresso.Id);
            if (deleted)
            {
                Snackbar.Add("Progresso excluído com sucesso.", Severity.Success);
                await LoadData();
            }
            else
            {
                Snackbar.Add("Erro ao excluir progresso.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao excluir progresso: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
    }
}

