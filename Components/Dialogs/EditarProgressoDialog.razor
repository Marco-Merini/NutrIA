@using NutriFlow.Models
@using NutriFlow.Services
@inject IProgressoService ProgressoService
@inject IPacienteService PacienteService
@inject IAuthService AuthService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Class="font-bold">Editar Progresso</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="success">
            <MudGrid Spacing="4">
                <MudItem xs="12">
                    <MudSelect T="int?" @bind-Value="ProgressoModel.PacienteId" Label="Paciente *" Placeholder="Selecione o paciente"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Selecione um paciente" Disabled="true">
                        @foreach (var p in Pacientes)
                        {
                            <MudSelectItem T="int?" Value="@p.Id">@p.Nome</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudDatePicker @bind-Date="ProgressoModel.DataRegistro" Label="Data do Registro"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="dd/MM/yyyy" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal?" @bind-Value="ProgressoModel.Peso" Label="Peso (kg)"
                                     Placeholder="" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal?" @bind-Value="ProgressoModel.PercentualGordura" Label="% Gordura"
                                     Placeholder="" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal?" @bind-Value="ProgressoModel.CinturaCm" Label="Cintura (cm)"
                                     Placeholder="" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal?" @bind-Value="ProgressoModel.QuadrilCm" Label="Quadril (cm)"
                                     Placeholder="" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="string" @bind-Value="ProgressoModel.AderenciaPlano" Label="Aderência ao Plano" Placeholder="Selecionar"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("Ruim")">Ruim</MudSelectItem>
                        <MudSelectItem Value="@("Regular")">Regular</MudSelectItem>
                        <MudSelectItem Value="@("Boa")">Boa</MudSelectItem>
                        <MudSelectItem Value="@("Muito Boa")">Muito Boa</MudSelectItem>
                        <MudSelectItem Value="@("Excelente")">Excelente</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="string" @bind-Value="ProgressoModel.Energia" Label="Nível de Energia" Placeholder="Selecionar"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("Muito Baixa")">Muito Baixa</MudSelectItem>
                        <MudSelectItem Value="@("Baixa")">Baixa</MudSelectItem>
                        <MudSelectItem Value="@("Moderada")">Moderada</MudSelectItem>
                        <MudSelectItem Value="@("Alta")">Alta</MudSelectItem>
                        <MudSelectItem Value="@("Muito Alta")">Muito Alta</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="string" @bind-Value="ProgressoModel.Humor" Label="Humor Geral" Placeholder="Selecionar"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("Muito Ruim")">Muito Ruim</MudSelectItem>
                        <MudSelectItem Value="@("Ruim")">Ruim</MudSelectItem>
                        <MudSelectItem Value="@("Neutro")">Neutro</MudSelectItem>
                        <MudSelectItem Value="@("Bom")">Bom</MudSelectItem>
                        <MudSelectItem Value="@("Muito Bom")">Muito Bom</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="ProgressoModel.Feedback" Label="Feedback / Observações" Lines="4"
                                  Placeholder="Como o paciente se sentiu, dificuldades encontradas..."
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Outlined" Class="rounded-lg text-none px-6">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Color="Color.Success" Variant="Variant.Filled" Class="rounded-lg text-none px-6"
                   Disabled="@IsSaving">
            @if (IsSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Salvando...</span>
            }
            else
            {
                <span>Salvar Alterações</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public Progresso ProgressoModel { get; set; } = new();

    private MudForm form = null!;
    private bool success;
    private bool IsSaving;

    private List<Paciente> Pacientes { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (AuthService.CurrentUser != null)
        {
            Pacientes = await PacienteService.GetPacientesByUsuarioIdAsync(AuthService.CurrentUser.Id);
        }
    }

    private async Task Salvar()
    {
        await form.Validate();
        if (!success) return;

        IsSaving = true;
        try
        {
            var updated = await ProgressoService.UpdateProgressoAsync(ProgressoModel);
            if (updated)
            {
                Snackbar.Add("Progresso atualizado com sucesso!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Erro ao atualizar progresso.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao atualizar progresso: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void Cancelar() => MudDialog.Cancel();
}
